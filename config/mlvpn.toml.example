# mlvpnd example configuration.
#
# Copy to /etc/mlvpn/mlvpn.toml, mode 0600, and adjust for your links.
# mlvpnd refuses to start if this file (or the private key file) is
# readable by group/other, so ownership matters:
#   - shipped systemd unit (runs as the `mlvpn` user from the start,
#     never root): chown mlvpn:mlvpn /etc/mlvpn/mlvpn.toml
#   - running mlvpnd as root and letting it drop privileges itself: the
#     config is read while still root, so root:root 0600 also works.
# See systemd/mlvpn.service for the full one-time setup.
#
# Run `mlvpnd genkey --out /etc/mlvpn/private.key` on each end first, then
# paste the resulting public keys into `peer_public_key` below (client's
# config gets the server's public key and vice versa).

mode = "client"   # "client" or "server" -- see ARCHITECTURE.md for what differs

[tunnel]
name = "mlvpn0"
address = "10.200.0.2/30"   # client and server must use addresses in the same /30
# address6 = "fd00:200::2/64"   # optional: also assign an IPv6 address to
                                 # mlvpn0, so it carries v4 and v6 traffic
                                 # at once. Uncomment on both ends with
                                 # addresses in the same /64.
mtu = 1400                  # upper bound, not a fixed value: auto-clamped down at
                             # startup if it would fragment against the bonded
                             # links' actual detected physical MTUs (see
                             # ARCHITECTURE.md's "MTU and MSS" section)
clamp_mss = true            # rewrite TCP SYN/SYN-ACK MSS options to fit the
                             # effective tunnel MTU instead of relying on PMTUD,
                             # which many networks silently black-hole

[crypto]
private_key_file = "/etc/mlvpn/private.key"   # must be mode 0600
peer_public_key = "REPLACE_WITH_PEER_PUBLIC_KEY_BASE64"
rekey_interval_secs = 120

[scheduler]
down_threshold = 5       # consecutive missed probes before a link is marked Down
up_threshold = 3         # consecutive good probes before a Down link is marked Up again
reorder_window_ms = 50   # max time to hold a gap open in the receive reorder buffer
ewma_alpha = 0.2         # smoothing factor for latency/jitter/loss/throughput stats

[logging]
level = "info"           # tracing-subscriber EnvFilter directive, e.g. "info" or "mlvpn=debug"

[control]
enabled = true           # exposes live stats to `mlvpn-tui`; see README.md "Monitoring"
# socket_path = "/run/mlvpn/mlvpn0.sock"   # default is /run/mlvpn/<tunnel.name>.sock

# One [[links]] block per physical uplink to bond together. Traffic is
# split across every link currently marked Up in proportion to its
# measured score (latency/jitter/loss/throughput, see monitor.rs) -- this
# combines their bandwidth rather than just failing over to a single
# "best" link. `weight` biases that split; `mlvpn-tui` shows the live
# result.

[[links]]
name = "fiber"
bind_interface = "eth0"
remote_addr = "203.0.113.10:51000"   # server's address:port for this link
local_port = 51000
weight = 1.0
probe_interval_ms = 200

[[links]]
name = "lte"
bind_interface = "wwan0"
remote_addr = "203.0.113.10:51001"
local_port = 51001
weight = 0.5                # bias away from a metered/slower link
bandwidth_cap_mbps = 20.0    # optional ceiling until real throughput is measured
probe_interval_ms = 200
