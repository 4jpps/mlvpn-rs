# mlvpnd example configuration.
#
# Copy to /etc/mlvpn/mlvpn.toml, mode 0600, and adjust for your links.
# mlvpnd refuses to start if this file (or the private key file) is
# readable by group/other, so ownership matters:
#   - shipped systemd unit (runs as the `mlvpn` user from the start,
#     never root): chown mlvpn:mlvpn /etc/mlvpn/mlvpn.toml
#   - running mlvpnd as root and letting it drop privileges itself: the
#     config is read while still root, so root:root 0600 also works.
# See systemd/mlvpn.service for the full one-time setup.
#
# Run `mlvpnd genkey --out /etc/mlvpn/private.key` on each end first, then
# paste the resulting public keys into `peer_public_key` below (client's
# config gets the server's public key and vice versa).

mode = "client"   # "client" or "server" -- see ARCHITECTURE.md for what differs

[tunnel]
name = "mlvpn0"
address = "10.200.0.2/30"   # client and server must use addresses in the same /30
# address6 = "fd00:200::2/64"   # optional: also assign an IPv6 address to
                                 # mlvpn0, so it carries v4 and v6 traffic
                                 # at once. Uncomment on both ends with
                                 # addresses in the same /64.
mtu = 1400                  # upper bound, not a fixed value: auto-clamped down at
                             # startup if it would fragment against the bonded
                             # links' actual detected physical MTUs (see
                             # ARCHITECTURE.md's "MTU and MSS" section)
clamp_mss = true            # rewrite TCP SYN/SYN-ACK MSS options to fit the
                             # effective tunnel MTU instead of relying on PMTUD,
                             # which many networks silently black-hole

[crypto]
private_key_file = "/etc/mlvpn/private.key"   # must be mode 0600
peer_public_key = "REPLACE_WITH_PEER_PUBLIC_KEY_BASE64"
rekey_interval_secs = 120

[scheduler]
down_threshold = 5       # consecutive missed probes before a link is marked Down
up_threshold = 3         # consecutive good probes before a Down link is marked Up again
reorder_window_ms = 50   # max time to hold a gap open in the receive reorder buffer
ewma_alpha = 0.2         # smoothing factor for latency/jitter/loss/throughput stats
# redundant_mode = false   # opt-in: send every packet on *every* Up link instead
                           # of picking one, trading bandwidth for reliability.
                           # Only worth it for a small, latency-critical tunnel --
                           # leave off for a normal bonded/bulk-transfer tunnel.
# auto_tune_reorder_window = false   # opt-in: periodically re-tune
                           # reorder_window_ms itself from the live RTT spread
                           # across bonded links, instead of leaving it fixed.
                           # Useful when bonding links with very different
                           # latency (e.g. fiber + a high-latency LTE link).
# reorder_window_min_ms = 10    # bounds the auto-tuner above; only consulted
# reorder_window_max_ms = 500   # when auto_tune_reorder_window is true
# auto_tune_probe_interval = false   # opt-in: let a link's probe interval
                           # back off above its own [[links]] probe_interval_ms
                           # floor after a long clean streak (less overhead
                           # on a stable link), snapping straight back to the
                           # floor the instant there's any miss at all.
# probe_interval_max_ms = 2000   # ceiling for the auto-tuner above; only
                           # consulted when auto_tune_probe_interval is true
# auto_tune_ewma_alpha = false   # opt-in: let a link's latency/jitter/loss/
                           # throughput smoothing factor move within
                           # [ewma_alpha_min, ewma_alpha_max] -- any miss
                           # jumps it to the max (fastest reaction), a long
                           # clean streak smooths it back toward the min.
# ewma_alpha_min = 0.05     # bounds the auto-tuner above; only consulted
# ewma_alpha_max = 0.5      # when auto_tune_ewma_alpha is true
# active_bandwidth_probing = false   # opt-in: periodically send a short,
                           # rate-limited burst of MTU-sized dummy packets on
                           # each link purely to measure achieved throughput,
                           # instead of only inferring it from real traffic
                           # that happens to be flowing. Injects real (if
                           # small and infrequent) extra traffic onto the
                           # wire, so this needs a stronger opt-in than the
                           # other auto-tuning knobs above -- leave off on a
                           # metered/bandwidth-constrained link.
# active_bandwidth_probe_interval_secs = 300   # how often each link runs one
                           # burst; validated to be >= 30s (this is an
                           # injected burst, not a single latency probe).
# active_bandwidth_probe_packets = 20   # packets per burst; validated to be
                           # between 2 and 100.

[logging]
level = "info"           # tracing-subscriber EnvFilter directive, e.g. "info" or "mlvpn=debug"

[control]
enabled = true           # exposes live stats to `mlvpn-tui`; see README.md "Monitoring"
# socket_path = "/run/mlvpn/mlvpn0.sock"   # default is /run/mlvpn/<tunnel.name>.sock

[command]
# enabled = false          # off by default: lets `mlvpnd set-link <link>
                           # <enable|disable>` pin a link out of scheduling at
                           # runtime, without editing this file and restarting.
                           # A separate socket from [control] above (different
                           # path, same 0600 permissions) so a client only
                           # authorized to read stats never gains the ability
                           # to redirect traffic. See ARCHITECTURE.md §9.
# socket_path = "/run/mlvpn/mlvpn0.command.sock"   # default is
                           # /run/mlvpn/<tunnel.name>.command.sock

# One [[links]] block per physical uplink to bond together. Traffic is
# split across every link currently marked Up in proportion to its
# measured score (latency/jitter/loss/throughput, see monitor.rs) -- this
# combines their bandwidth rather than just failing over to a single
# "best" link. `weight` biases that split; `mlvpn-tui` shows the live
# result.
#
# Each link is independently IPv4 or IPv6, inferred from remote_addr
# (bracket the host for IPv6, e.g. "[2001:db8::1]:51000") or, on a
# server-side link with no remote_addr, from local_addr (e.g. "::" for
# "any IPv6"). A single tunnel can freely mix address families across
# its links -- see ARCHITECTURE.md §6.
#
# remote_addr also accepts a DNS hostname instead of a literal IP, e.g.
# "bgp.example.com:51000" -- handy when the server side doesn't have a
# fixed IP you want to hard-code into every client. Resolved once, at
# startup; a restart is needed to pick up a changed IP behind the
# hostname, same as editing a literal IP here always required. If the
# hostname has both an A and AAAA record (ordinary dual-stack DNS),
# IPv6 is preferred automatically unless local_addr below pins this
# link to a specific family.

[[links]]
name = "fiber"
bind_interface = "eth0"
remote_addr = "203.0.113.10:51000"   # server's address:port for this link
                                     # (a hostname like "bgp.example.com:51000"
                                     # works here too -- see note above)
local_port = 51000
weight = 1.0
probe_interval_ms = 200

[[links]]
name = "lte"
bind_interface = "wwan0"
remote_addr = "203.0.113.10:51001"
local_port = 51001
weight = 0.5                # bias away from a metered/slower link
bandwidth_cap_mbps = 20.0    # optional hard ceiling: the scheduler stops sending
                             # more to this link once it's hit this rate in the
                             # current second, picking another link instead
probe_interval_ms = 200
