# Rust build artifacts
/target/
**/target/

# Debian packaging build output (debian/rules writes into these; the
# actual .deb/.changes/.dsc/.buildinfo land one directory *above* the
# source tree per dpkg convention, so they're not under here, but ignore
# the in-tree scratch dirs debhelper/cargo create during the build)
/debian/mlvpn/
/debian/.debhelper/
/debian/cargo_home/
/debian/*.substvars
/debian/*.debhelper.log
/debian/files
/debian/debhelper-build-stamp
obj-*-linux-gnu/

# In case a built package ever ends up copied into the tree
*.deb
*.buildinfo
*.changes
*.dsc

# Editor / OS cruft
.vscode/
.idea/
*.swp
.DS_Store

# Real key material generated by `mlvpnd genkey` should never be
# committed -- only the public key goes in a config/peer_public_key
# field, never the private half.
*.key
private.key
